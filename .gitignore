lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ====================================================================
# Thư mục biên dịch C++ & Cấu hình CMake
# ====================================================================
# Thư mục build chính của CMake (bắt buộc phải bỏ qua)
build/
Build/

# Các file sinh ra bởi hệ thống cấu hình CMake
CMakeCache.txt
CMakeFiles/
CMakeSystem.cmake
cmake_install.cmake
Makefile
targets
*.cmake

# ====================================================================
# Các file thực thi và Thư viện đã biên dịch (Binaries & Libraries)
# ====================================================================
# File thực thi độc lập
*.exe
*.out
*.app
sudoku_test

# File đối tượng biên dịch trung gian
*.o
*.obj

# Thư viện liên kết tĩnh và động (C/C++ & Python C-Extensions)
*.a
*.lib
*.so
*.dylib
*.dll
*.pyd

# ====================================================================
# Cấu hình của các IDE và Editor (VS Code, PyCharm, CLion...)
# ====================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# ====================================================================
# File rác sinh ra bởi Hệ điều hành (OS generated files)
# ====================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ====================================================================
# Dữ liệu ảnh và các tệp tin dữ liệu sinh ra khi chạy ứng dụng
# ====================================================================
# Bỏ qua tất cả các định dạng ảnh phổ biến
*.jpg
*.jpeg
*.png
*.bmp
*.gif
*.tiff
*.webp

# Bỏ qua các thư mục debug và thư mục cắt ô sinh ra khi chạy thử nghiệm
**/debug_*/
**/cells_*/

# Bỏ qua các tệp tin dữ liệu (.dat)
*.dat